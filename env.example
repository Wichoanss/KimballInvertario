# =============================================================================
# SmartRack — Archivo de configuracion de produccion
# Instrucciones:
#   1. Copiar este archivo como ".env" junto al SmartRack.exe
#   2. Rellenar TODOS los campos marcados con [OBLIGATORIO]
#   3. NUNCA compartir este archivo ni subirlo a control de versiones
#   4. El sistema emite advertencias en log si detecta credenciales default
# =============================================================================

# --- Conexion al servidor SmartRack ---
# [OBLIGATORIO] URL completa del servidor (sin / al final)
API_BASE_URL=http://192.168.1.100:8081

# [OBLIGATORIO] Cambiar por credenciales reales — no usar los defaults
API_USERNAME=CAMBIAR_USUARIO
API_PASSWORD=CAMBIAR_CONTRASEÑA

# --- Panel de Configuracion de Lineas ---
# [OBLIGATORIO] Credenciales para acceder a /config en la interfaz web
CONFIG_USERNAME=CAMBIAR_ADMIN
CONFIG_PASSWORD=CAMBIAR_CONTRASEÑA_ADMIN

# --- Servidor FastAPI ---
# Puerto en el que escucha la interfaz web
SERVER_PORT=4500

# --- Polling ---
# Cada cuantos segundos se consulta el SmartRack (default: 5)
POLL_INTERVAL_SECONDS=5
# Cada cuantos segundos se renueva el token de autenticacion (default: 86400 = 24h)
LOGIN_INTERVAL_SECONDS=86400

# --- Logging ---
# Nivel de detalle: DEBUG | INFO | WARNING | ERROR
# En produccion usar INFO o WARNING
LOG_LEVEL=INFO

# --- Base de datos ---
# Nombre del archivo SQLite (se crea junto al .exe automaticamente)
DB_NAME=inventory.db
