# =============================================================================
# SmartRack — Archivo de configuracion
# Coloca este archivo junto al main.exe (o junto a main.py en desarrollo)
# Los valores aqui sobreescriben los defaults del sistema.
# Las lineas que empiezan con # son comentarios y se ignoran.
# =============================================================================

# --- Conexion al servidor SmartRack ---
API_BASE_URL=http://localhost:8081
API_USERNAME=USER
API_PASSWORD=AUTOSMD

# --- Servidor FastAPI ---
# Puerto en el que escucha la interfaz web
SERVER_PORT=4500

# --- Polling ---
# Cada cuantos segundos se consulta el SmartRack (default: 5)
POLL_INTERVAL_SECONDS=5
# Cada cuantos segundos se renueva el token de autenticacion (default: 86400 = 24h)
LOGIN_INTERVAL_SECONDS=86400

# --- Logging ---
# Nivel de detalle del log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Nombre del archivo de log (se crea junto al .exe)
LOG_FILE=smartrack.log

# --- Base de datos ---
# Nombre del archivo SQLite (se crea junto al .exe)
DB_NAME=inventory.db
