# ============================================================
#  SmartRack — Archivo de configuracion
#  Copiar a la maquina destino junto al SmartRack.exe
#  Renombrar este archivo a: .env
# ============================================================

# --- URL del servidor SmartRack (obligatorio) ---
API_BASE_URL=http://192.168.1.100:8081

# --- Credenciales de la API SmartRack (obligatorio) ---
API_USERNAME=TU_USUARIO
API_PASSWORD=TU_PASSWORD

# --- Credenciales del panel de configuracion web ---
CONFIG_USERNAME=admin
CONFIG_PASSWORD=CAMBIAR_EN_PRODUCCION

# --- Puerto donde escucha el servidor (default: 4500) ---
SERVER_PORT=4500

# --- Intervalo de actualizacion del inventario en segundos (default: 5) ---
POLL_INTERVAL_SECONDS=5

# --- Nivel de log: DEBUG | INFO | WARNING | ERROR (default: INFO) ---
LOG_LEVEL=INFO

# --- Nombres de archivos (opcionales, dejar por defecto en maquila) ---
# DB_NAME=inventory.db
# LOG_FILE=smartrack.log
