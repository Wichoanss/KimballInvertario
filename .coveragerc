[run]
omit =
    mock_smartrack_server.py
    verify_mock.py
    test_mock_server.py
    debug_db_logic.py
    inspect_realdata.py
    generate_pptx.py
    tests/*
    */__init__.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if __name__ == __main__:
    raise NotImplementedError
    if TYPE_CHECKING:
